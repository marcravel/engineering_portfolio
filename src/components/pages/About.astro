const t = texts[lang];
---

<BaseLayout title={t.title}>
    <section class="py-5">
        <div class="container text-light">
            <h1 class="display-4 fw-bold mb-5 section-title">{t.h1}</h1>
            
            <div class="row g-5">
                <!-- Left Column: Bio & Skills -->
                <div class="col-lg-7">
                    <!-- Professional Summary -->
                    <div class="mb-5">
                        <h3 class="h4 mb-3" style="color: var(--color-emerald);">{t.profSummary}</h3>
                        <p class="lead" style="color: var(--color-text-muted);">
                            {t.profDesc}
                        </p>
                    </div>

                    <!-- Technical Skills Matrix -->
                    <div class="mb-5">
                        <h3 class="h4 mb-4" style="color: var(--color-emerald);">{t.techMatrix}</h3>
                        
                        <div class="mb-4">
                            <h5 class="h6 text-uppercase text-secondary mb-2">{t.hwEmb}</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge bg-dark-subtle border border-secondary text-light px-3 py-2">PIC</span>
                                <span class="badge bg-dark-subtle border border-secondary text-light px-3 py-2">STM32</span>
                                <span class="badge bg-dark-subtle border border-secondary text-light px-3 py-2">ESP32</span>
                                <span class="badge bg-dark-subtle border border-secondary text-light px-3 py-2">Arduino</span>
                                <span class="badge bg-dark-subtle border border-secondary text-light px-3 py-2">PCB Design</span>
                                <span class="badge bg-dark-subtle border border-secondary text-light px-3 py-2">Circuit Design</span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h5 class="h6 text-uppercase text-secondary mb-2">{t.softAi}</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge bg-dark-subtle border border-success text-success px-3 py-2">C/C++</span>
                                <span class="badge bg-dark-subtle border border-success text-success px-3 py-2">Python</span>
                                <span class="badge bg-dark-subtle border border-success text-success px-3 py-2">OpenCV</span>
                                <span class="badge bg-dark-subtle border border-success text-success px-3 py-2">Fuzzy Logic</span>
                                <span class="badge bg-dark-subtle border border-success text-success px-3 py-2">ROS2</span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h5 class="h6 text-uppercase text-secondary mb-2">{t.toolsMulti}</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge bg-dark-subtle border border-info text-info px-3 py-2">Git</span>
                                <span class="badge bg-dark-subtle border border-info text-info px-3 py-2">HTML/CSS/JS</span>
                                <span class="badge bg-dark-subtle border border-info text-info px-3 py-2">Linux</span>
                                <span class="badge bg-dark-subtle border border-info text-info px-3 py-2">Video Editing</span>
                                <span class="badge bg-dark-subtle border border-info text-info px-3 py-2">YouTube "Code & Copper" Management</span>
                            </div>
                        </div>
                    </div>

                    <!-- Languages -->
                    <div class="mb-5">
                        <h3 class="h4 mb-3" style="color: var(--color-emerald);">{t.languages}</h3>
                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center text-light">
                                <strong class="text-white">English</strong>
                                <div class="flex-grow-1 border-bottom border-secondary mx-3" style="opacity: 0.3; border-bottom-style: dashed !important;"></div>
                                <span>{t.langLvl.pro}</span>
                            </div>
                            <div class="d-flex align-items-center text-light">
                                <strong class="text-white">French</strong>
                                <div class="flex-grow-1 border-bottom border-secondary mx-3" style="opacity: 0.3; border-bottom-style: dashed !important;"></div>
                                <span>{t.langLvl.fluent}</span>
                            </div>
                            <div class="d-flex align-items-center text-light">
                                <strong class="text-white">Turkish</strong>
                                <div class="flex-grow-1 border-bottom border-secondary mx-3" style="opacity: 0.3; border-bottom-style: dashed !important;"></div>
                                <span>{t.langLvl.fluent}</span>
                            </div>
                            <div class="d-flex align-items-center text-light">
                                <strong class="text-white">German</strong>
                                <div class="flex-grow-1 border-bottom border-secondary mx-3" style="opacity: 0.3; border-bottom-style: dashed !important;"></div>
                                <span>A1</span>
                            </div>
                            <div class="d-flex align-items-center text-light">
                                <strong class="text-white">Malagasy</strong>
                                <div class="flex-grow-1 border-bottom border-secondary mx-3" style="opacity: 0.3; border-bottom-style: dashed !important;"></div>
                                <span>{t.langLvl.native}</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Education & Experience -->
                <div class="col-lg-5">
                    <h3 class="h4 mb-4" style="color: var(--color-emerald);">{t.eduHonors}</h3>
                    
                    <!-- Education Card 1 -->
                    <div class="card bg-dark-subtle border-secondary mb-4 p-4 shadow-sm edu-card">
                        <h5 class="text-white fw-bold mb-1">{t.edu1.title}</h5>
                        <p class="text-success mb-2 small fw-semibold">{t.edu1.year}</p>
                        <p class="text-light opacity-75 small mb-2">{t.edu1.loc}</p>
                        <div class="mt-2">
                            <span class="badge bg-success bg-opacity-25 text-success border border-success px-2 py-1">{t.edu1.badge}</span>
                        </div>
                    </div>

                    <!-- Education Card 2 -->
                    <div class="card bg-dark-subtle border-secondary mb-4 p-4 shadow-sm edu-card">
                        <h5 class="text-white fw-bold mb-1">{t.edu2.title}</h5>
                        <p class="text-success mb-2 small fw-semibold">{t.edu2.year}</p>
                        <p class="text-light opacity-75 small mb-2">{t.edu2.loc}</p>
                        <div class="mt-2">
                            <span class="badge bg-secondary bg-opacity-25 text-light border border-secondary px-2 py-1">{t.edu2.badge}</span>
                        </div>
                    </div>

                    <h3 class="h4 mb-4 mt-5" style="color: var(--color-emerald);">{t.experience}</h3>
                    
                    <!-- Experience Card 1 -->
                    <div class="card bg-dark-subtle border-secondary mb-4 p-4 shadow-sm edu-card">
                        <h5 class="text-white fw-bold mb-1">{t.exp1.title}</h5>
                        <p class="text-success mb-2 small fw-semibold">{t.exp1.year}</p>
                        <p class="text-light opacity-75 small mb-3">{t.exp1.loc}</p>
                        <ul class="small text-light opacity-75 mb-0 ps-3">
                            <li class="mb-1">{t.exp1.li1}</li>
                            <li class="mb-1">{t.exp1.li2}</li>
                            <li>{t.exp1.li3}</li>
                        </ul>
                    </div>

                    <h3 class="h4 mb-4 mt-5" style="color: var(--color-emerald);">{t.courses}</h3>
                    
                    <!-- Courses card 1-->
                    <div class="card bg-dark-subtle border-secondary mb-4 p-4 shadow-sm edu-card">
                        <h5 class="text-white fw-bold mb-1">{t.course1.title}</h5>
                        <p class="text-success mb-2 small fw-semibold">{t.course1.year}</p>
                        <p class="text-light opacity-75 small mb-3">{t.course1.loc}</p>
                        <ul class="small text-light opacity-75 mb-0 ps-3">
                            <li class="mb-1">{t.course1.li1}</li>
                            <li class="mb-1">{t.course1.li2}</li>
                            <li>{t.course1.li3}</li>
                        </ul>
                    </div>

                    <!-- Courses card 2-->
                    <div class="card bg-dark-subtle border-secondary mb-4 p-4 shadow-sm edu-card">
                        <h5 class="text-white fw-bold mb-1">{t.course2.title}</h5>
                        <p class="text-success mb-2 small fw-semibold">{t.course2.year}</p>
                        <p class="text-light opacity-75 small mb-3">{t.course2.loc}</p>
                        <ul class="small text-light opacity-75 mb-0 ps-3">
                            <li class="mb-1">{t.course2.li1}</li>
                        </ul>
                    </div>

                    <!-- Courses card 3-->
                     <div class="card bg-dark-subtle border-secondary mb-4 p-4 shadow-sm edu-card">
                        <h5 class="text-white fw-bold mb-1">{t.course3.title}</h5>
                        <p class="text-success mb-2 small fw-semibold">{t.course3.year}</p>
                        <p class="text-light opacity-75 small mb-3">{t.course3.loc}</p>
                        <ul class="small text-light opacity-75 mb-0 ps-3">
                            <li class="mb-1">{t.course3.li1}</li>
                        </ul>
                    </div>

                    <h3 class="h4 mb-4 mt-5" style="color: var(--color-emerald);">{t.community}</h3>
                    
                    <!-- Community card 1-->
                    <div class="card bg-dark-subtle border-secondary mb-4 p-4 shadow-sm edu-card">
                        <h5 class="text-white fw-bold mb-1">{t.com1.title}</h5>
                        <p class="text-success mb-2 small fw-semibold">{t.com1.year}</p>
                        <p class="text-light opacity-75 small mb-3">{t.com1.loc}</p>
                        <ul class="small text-light opacity-75 mb-0 ps-3">
                            <li class="mb-1">{t.com1.li1}</li>
                            <li class="mb-1">{t.com1.li2}</li>
                            <li class="mb-1">{t.com1.li3}</li>
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
/* Hover Effects for Cards matching ProjectCards */
.edu-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    border-radius: var(--radius-md);
    background-color: var(--color-bg-dark-secondary) !important;
}

.edu-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover) !important;
    border-color: rgba(16, 185, 129, 0.3) !important;
    border-width: 2px !important;
}

/* Base adjustment for the bg-dark-subtle utility to fit our theme better */
.bg-dark-subtle {
    background-color: var(--color-bg-dark-secondary) !important;
}
</style>
