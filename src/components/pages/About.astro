const t = texts[lang];
---

<BaseLayout title={t.title}>
    <section class="section">
        <div class="container animate-fade-up">
            <h1 class="section-title"><span>{t.h1}</span></h1>

            <div class="grid grid-cols-1 md-grid-cols-2 lg-grid-cols-2 gap-5">
                <!-- Left Column: Bio & Skills -->
                <div>
                    <!-- Professional Summary -->
                    <div class="glass p-4 p-md-5 mb-5">
                        <h3
                            class="mb-3"
                            style="color: var(--color-accent-1); font-size: 1.5rem;"
                        >
                            {t.profSummary}
                        </h3>
                        <p
                            class="lead"
                            style="color: var(--color-text-secondary); font-size: 1.1rem; line-height: 1.8;"
                        >
                            {t.profDesc}
                        </p>
                    </div>

                    <!-- Technical Skills Matrix -->
                    <div class="glass p-4 p-md-5 mb-5">
                        <h3
                            class="mb-4"
                            style="color: var(--color-accent-2); font-size: 1.5rem;"
                        >
                            {t.techMatrix}
                        </h3>

                        <div class="mb-4">
                            <h5
                                class="text-uppercase mb-3 small fw-bold"
                                style="color: var(--color-text-secondary); letter-spacing: 1px;"
                            >
                                {t.hwEmb}
                            </h5>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge px-3 py-2">PIC</span>
                                <span class="badge px-3 py-2">STM32</span>
                                <span class="badge px-3 py-2">ESP32</span>
                                <span class="badge px-3 py-2">Arduino</span>
                                <span class="badge px-3 py-2">PCB Design</span>
                                <span class="badge px-3 py-2"
                                    >Circuit Design</span
                                >
                            </div>
                        </div>

                        <div class="mb-4">
                            <h5
                                class="text-uppercase mb-3 small fw-bold"
                                style="color: var(--color-text-secondary); letter-spacing: 1px;"
                            >
                                {t.softAi}
                            </h5>
                            <div class="d-flex flex-wrap gap-2">
                                <span
                                    class="badge px-3 py-2"
                                    style="border-color: rgba(59, 130, 246, 0.5); color: #60a5fa;"
                                    >C/C++</span
                                >
                                <span
                                    class="badge px-3 py-2"
                                    style="border-color: rgba(59, 130, 246, 0.5); color: #60a5fa;"
                                    >Python</span
                                >
                                <span
                                    class="badge px-3 py-2"
                                    style="border-color: rgba(59, 130, 246, 0.5); color: #60a5fa;"
                                    >OpenCV</span
                                >
                                <span
                                    class="badge px-3 py-2"
                                    style="border-color: rgba(59, 130, 246, 0.5); color: #60a5fa;"
                                    >Fuzzy Logic</span
                                >
                                <span
                                    class="badge px-3 py-2"
                                    style="border-color: rgba(59, 130, 246, 0.5); color: #60a5fa;"
                                    >ROS2</span
                                >
                            </div>
                        </div>

                        <div class="mb-4">
                            <h5
                                class="text-uppercase mb-3 small fw-bold"
                                style="color: var(--color-text-secondary); letter-spacing: 1px;"
                            >
                                {t.toolsMulti}
                            </h5>
                            <div class="d-flex flex-wrap gap-2">
                                <span
                                    class="badge px-3 py-2"
                                    style="border-color: rgba(139, 92, 246, 0.5); color: #c084fc;"
                                    >Git</span
                                >
                                <span
                                    class="badge px-3 py-2"
                                    style="border-color: rgba(139, 92, 246, 0.5); color: #c084fc;"
                                    >HTML/CSS/JS</span
                                >
                                <span
                                    class="badge px-3 py-2"
                                    style="border-color: rgba(139, 92, 246, 0.5); color: #c084fc;"
                                    >Linux</span
                                >
                                <span
                                    class="badge px-3 py-2"
                                    style="border-color: rgba(139, 92, 246, 0.5); color: #c084fc;"
                                    >Video Editing</span
                                >
                                <span
                                    class="badge px-3 py-2"
                                    style="border-color: rgba(139, 92, 246, 0.5); color: #c084fc;"
                                    >YouTube "Code & Copper" Management</span
