                            <li class="mb-2">{t.exp1.li1}</li>
                            <li class="mb-2">{t.exp1.li2}</li>
                            <li>{t.exp1.li3}</li>
                        </ul>
                    </div>

                    <h3
                        class="mb-4 mt-5"
                        style="color: var(--color-accent-2); font-size: 1.5rem;"
