        },
        courses: "Kurslar",
        course1: {
            title: "Modern Robotik, Kurs 1: Robot Hareketinin Temeli",
            year: "Şub 2023",
            loc: "MOOC | Northwestern University, Coursera",
            li1: "Temel robotik kavramlarına (konfigürasyon uzayı) hakim olundu",
            li2: "Doğrusal cebir ilkeleri Python kullanarak uygulandı",
            li3: "CoppeliaSim robot simülatörü kullanıldı"
        },
        course2: {
            title: "Web Geliştiricileri İçin HTML, CSS ve Javascript",
            year: "Tem 2023 - Ağu 2023",
            loc: "MOOC | Johns Hopkins University, Coursera",
            li1: "Bootstrap bileşenleri kullanarak duyarlı web sayfaları oluşturuldu"
        },
        course3: {
            title: "Mühendislik ve Matematik için İngilizce",
            year: "May 2023",
            loc: "MOOC | ABD Dışişleri Bakanlığı sponsorluğunda",
            li1: "Çevrimiçi bir kurs aracılığıyla STEM konularının anlaşılması ve dil yeterliliği artırıldı"
        },
        community: "Topluluk Katılımı",
        com1: {
            title: "Multimedya Koordinatörü",
            year: "Ara 2025'ten beri",
            loc: "Türkiye'de Malgaş Kültür ve Dayanışma Derneği",
            li1: "Derneğin çevrimiçi varlığının sağlanması",
