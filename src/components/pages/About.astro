        },
        community: "Engagement Communautaire",
        com1: {
            title: "Coordinateur Multimédia",
            year: "Depuis Déc 2025",
            loc: "Association de Culture et de Solidarité Malgache en Turquie",
            li1: "Assurer la présence et la visibilité en ligne",
            li2: "Organisation d'événements et d'activités",
            li3: "Établir et maintenir des relations avec les membres"
        }
    },
    tr: {
        title: "Hakkımda - Marc",
        h1: "Hakkımda",
        profSummary: "Profesyonel Özet",
        profDesc: "Donanım, Gömülü Sistemler ve Yapay Zeka/Bilgisayarlı Görme'nin kesişim noktasında sistem tasarlama ve kurma konusunda güçlü bir temele sahip bir elektrik ve elektronik mühendisliği öğrencisiyim. Gömülü mantığı (PIC, STM32, ESP32) programlamaktan gelişmiş sensör mimarileri geliştirmeye kadar akıllı, duyarlı çözümler yaratıyorum.",
        techMatrix: "Teknik Yetenek Matrisi",
