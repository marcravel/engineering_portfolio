---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, useTranslatedPath, getRouteFromUrl, languages, flags } from '../i18n/ui';

const { title = "Marc | Engineering Portfolio" } = Astro.props;
const currentPath = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const route = getRouteFromUrl(Astro.url);
---
<!DOCTYPE html>
<html lang={lang}>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />

    <!-- Google Fonts are now imported in global.css -->
        
    <!-- Client-side Routing and Language Auto-Detection -->
    <script is:inline>
        (function() {
            try {
                const storedLang = localStorage.getItem('preferredLang');
                const browserLang = navigator.language.split('-')[0];
                const supportedLangs = ['en', 'fr', 'tr'];
                const defaultLang = 'en';

                const currentPath = window.location.pathname;
                const basePath = '/engineering_portfolio';
                let pathWithoutBase = currentPath.replace(basePath, '');
                if(!pathWithoutBase.startsWith('/')) pathWithoutBase = '/' + pathWithoutBase;
                
                const currentDocLang = supportedLangs.find(l => pathWithoutBase.startsWith(`/${l}/`) || pathWithoutBase === `/${l}`) || defaultLang;

                if (!storedLang) {
                    const targetLang = supportedLangs.includes(browserLang) ? browserLang : defaultLang;
                    if (targetLang !== defaultLang && currentDocLang === defaultLang && (pathWithoutBase === '/' || pathWithoutBase === '')) {
                        localStorage.setItem('preferredLang', targetLang);
                        window.location.replace(basePath + '/' + targetLang + '/');
                    }
                }
            } catch(e) {}
        })();
    </script>
</head>

<body class="d-flex flex-column">
    <!-- ===================== NAVBAR ===================== -->
    <header class="navbar-wrapper">
        <div class="container py-3">
            <nav id="main-nav" class="glass d-flex align-items-center justify-content-between px-4 py-2">
                <a class="fw-bold fs-4 text-decoration-none gradient-text" href={translatePath('/')} style="font-family: var(--font-display);">Marc</a>
                
                <!-- Desktop Menu -->
                <ul class="nav-links d-none lg-d-flex align-items-center gap-4 m-0" style="list-style: none;">
                    <li>
                        <a class:list={['nav-link', { active: route === '/' }]} href={translatePath('/')}>{t('nav.home')}</a>
                    </li>
                    <li>
                        <a class:list={['nav-link', { active: route.includes('/about') }]} href={translatePath('/about')}>{t('nav.about')}</a>
                    </li>
                    <li>
                        <a class:list={['nav-link', { active: route.includes('/projects') }]} href={translatePath('/projects')}>{t('nav.projects')}</a>
                    </li>
                    <li>
                        <a class:list={['nav-link', { active: route.includes('/contacts') }]} href={translatePath('/contacts')}>{t('nav.contact')}</a>
                    </li>
                </ul>

                <div class="d-flex align-items-center gap-3">
                    <!-- Language Switcher -->
                    <div class="dropdown-wrapper position-relative">
                        <button id="langToggle" class="btn btn-outline py-2 px-3 badge d-flex align-items-center gap-2 m-0" style="font-size: 1rem; border-radius: 99px;">
                            {flags[lang]}
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                        </button>
                        <div id="langMenu" class="dropdown-menu glass position-absolute d-none flex-column mt-2 p-2" style="right: 0; min-width: 120px; z-index: 1000;">
                            {Object.entries(languages).map(([code, name]) => (
                                <a class="dropdown-item d-flex align-items-center gap-2 p-2 text-decoration-none" href={translatePath(route, code as keyof typeof languages)} onclick={`localStorage.setItem('preferredLang', '${code}')`}>
                                    <span>{flags[code as keyof typeof languages]}</span>
                                    <span>{name}</span>
                                </a>
                            ))}
                        </div>
                    </div>

                    <!-- Mobile Menu Toggle -->
                    <button id="mobileMenuToggle" class="btn btn-outline p-2 lg-d-none" aria-label="Toggle navigation" style="border-radius: 8px;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
                    </button>
                </div>
            </nav>
            
            <!-- Mobile Menu -->
            <div id="mobileMenu" class="glass mt-2 p-3 d-none flex-column gap-3 lg-d-none animate-fade-up">
                <a class:list={['nav-link', { active: route === '/' }]} href={translatePath('/')}>{t('nav.home')}</a>
                <a class:list={['nav-link', { active: route.includes('/about') }]} href={translatePath('/about')}>{t('nav.about')}</a>
                <a class:list={['nav-link', { active: route.includes('/projects') }]} href={translatePath('/projects')}>{t('nav.projects')}</a>
                <a class:list={['nav-link', { active: route.includes('/contacts') }]} href={translatePath('/contacts')}>{t('nav.contact')}</a>
            </div>
        </div>
    </header>

    <main class="flex-grow-1">
        <slot />
    </main>

    <!-- ===================== FOOTER ===================== -->
    <footer class="py-5 mt-auto glass" style="border-radius: 0; border-bottom: none; border-left: none; border-right: none;">
        <div class="container text-center small text-muted">
            <div class="mb-3">
                © <span id="currentYear"></span> Marc — Engineering Portfolio
            </div>
            <div class="d-flex justify-content-center gap-4">
                <a href="https://github.com/marcravel" target="_blank" rel="noopener noreferrer"
                    class="text-decoration-none hover-accent">{t('footer.github')}</a>
                <a href="https://www.linkedin.com/in/marc-anjaniaina-ravelontsalama/" target="_blank"
                    rel="noopener noreferrer" class="text-decoration-none hover-accent">{t('footer.linkedin')}</a>
                <a href={translatePath('/contacts')} class="text-decoration-none hover-accent">{t('footer.contact')}</a>
            </div>
        </div>
    </footer>

    <style>
        .navbar-wrapper {
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .nav-link {
            color: var(--color-text-secondary);
            font-weight: 500;
            position: relative;
            text-decoration: none;
            padding: 0.5rem;
            display: block;
        }

        .nav-link:hover, .nav-link.active {
            color: var(--color-text-primary);
        }

        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 0;
            background: linear-gradient(to right, var(--color-accent-1), var(--color-accent-2));
            transition: width 0.3s;
        }

        .nav-link:hover::after, .nav-link.active::after {
            width: 100%;
        }
        
        .hover-accent:hover {
            color: var(--color-accent-1);
        }

        .dropdown-item {
            color: var(--color-text-secondary);
            border-radius: 8px;
            transition: background 0.2s, color 0.2s;
        }

        .dropdown-item:hover {
            background: rgba(255,255,255,0.05);
            color: var(--color-text-primary);
        }
        
        .flex-grow-1 {
            flex-grow: 1;
        }
    </style>

    <!-- ===================== SCRIPTS ===================== -->
    <script src="/assets/js/main.js" is:inline></script>
    <script is:inline>
        document.getElementById('currentYear').textContent = new Date().getFullYear();

        // Custom UI interactions
        document.addEventListener("DOMContentLoaded", function () {
            // Mobile Menu
            const mobileMenuToggle = document.getElementById('mobileMenuToggle');
            const mobileMenu = document.getElementById('mobileMenu');
            
            if (mobileMenuToggle && mobileMenu) {
                mobileMenuToggle.addEventListener('click', () => {
                    if (mobileMenu.classList.contains('d-none')) {
                        mobileMenu.classList.remove('d-none');
                        mobileMenu.classList.add('d-flex');
                    } else {
                        mobileMenu.classList.add('d-none');
                        mobileMenu.classList.remove('d-flex');
                    }
                });
            }

            // Language Dropdown
            const langToggle = document.getElementById('langToggle');
            const langMenu = document.getElementById('langMenu');
            
            if (langToggle && langMenu) {
                langToggle.addEventListener('click', (e) => {
                    e.stopPropagation();
                    if (langMenu.classList.contains('d-none')) {
                        langMenu.classList.remove('d-none');
                        langMenu.classList.add('d-flex');
                    } else {
                        langMenu.classList.add('d-none');
                        langMenu.classList.remove('d-flex');
                    }
                });

                // Close dropdown when clicking outside
                document.addEventListener('click', () => {
                    if (!langMenu.classList.contains('d-none')) {
                        langMenu.classList.add('d-none');
                        langMenu.classList.remove('d-flex');
                    }
                });
            }
        });
    </script>
</body>

</html>