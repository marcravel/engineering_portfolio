---
import '../styles/global.css';
const { title = "Marc | Engineering Portfolio" } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />

    <!-- Bootstrap 5 CSS (CDN) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;700&display=swap"
        rel="stylesheet">
</head>

<body>
    <!-- ===================== NAVBAR ===================== -->
    <nav id="main-nav" class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href={`${import.meta.env.BASE_URL}`}>Marc</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class:list={['nav-link', { active: currentPath === import.meta.env.BASE_URL || currentPath === import.meta.env.BASE_URL + '/' }]} href={`${import.meta.env.BASE_URL}`}>Home</a>
                    </li>
                    <li class="nav-item">
                        <a class:list={['nav-link', { active: currentPath.includes('/about') }]} href={`${import.meta.env.BASE_URL}/about`}>About</a>
                    </li>
                    <li class="nav-item">
                        <a class:list={['nav-link', { active: currentPath.includes('/projects') }]} href={`${import.meta.env.BASE_URL}/projects`}>Projects</a>
                    </li>
                    <li class="nav-item">
                        <a class:list={['nav-link', { active: currentPath.includes('/contacts') }]} href={`${import.meta.env.BASE_URL}/contacts`}>Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <slot />

    <!-- ===================== FOOTER ===================== -->
    <footer class="py-4 footer-section bg-dark text-light mt-auto">
        <div class="container text-center small">
            <div class="mb-2">
                © <span id="currentYear"></span> Marc — Engineering Portfolio
            </div>
            <div>
                <a href="https://github.com/marcravel" target="_blank" rel="noopener noreferrer"
                    class="text-decoration-none text-light-50 me-2">GitHub</a>
                <a href="https://www.linkedin.com/in/marc-anjaniaina-ravelontsalama/" target="_blank"
                    rel="noopener noreferrer" class="text-decoration-none text-light-50 me-2">LinkedIn</a>
                <a href={`${import.meta.env.BASE_URL}contacts`} class="text-decoration-none text-light-50">Contact</a>
            </div>
        </div>
    </footer>

    <!-- ===================== SCRIPTS ===================== -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous">
        </script>
    <script src="/assets/js/main.js" is:inline></script>
    <script is:inline>
        document.getElementById('currentYear').textContent = new Date().getFullYear();

        // Transparent to Glassy Navbar Logic
        document.addEventListener("DOMContentLoaded", function () {
            const el_navbar = document.getElementById('main-nav');
            if (el_navbar) {
                window.addEventListener('scroll', function () {
                    if (window.scrollY > 10) {
                        el_navbar.classList.add('scrolled');
                    } else {
                        el_navbar.classList.remove('scrolled');
                    }
                });
            }
        });
    </script>
</body>

</html>