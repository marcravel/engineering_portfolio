---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../ProjectCard.astro";
import projectsData from "../../data/projects.json";
import profileImg from "../../assets/profile.jpeg";
import { useTranslatedPath } from "../../i18n/ui";

export interface Props {
    lang: "en" | "fr" | "tr";
}
const { lang } = Astro.props;
const translatePath = useTranslatedPath(lang);

const activeProjects = projectsData.filter((project) => project.active);
const gridClassDesktop =
    activeProjects.length === 2 ? "lg-grid-cols-2" : "lg-grid-cols-3";

const texts = {
    en: {
        portfolio: "👋 Welcome to my engineering portfolio",
        greeting: "Hi, I'm Marc.",
        subtitle: "Electronics, Embedded Systems & Robotics",
        intro: "I'm a 3rd-year Electrical and Electronics Engineering student at Selçuk University, working across robotics, computer vision, AI, and embedded systems. I'm mostly software-side (Python, C/C++, and Linux) but I get my hands on the hardware when needed.",
        view_projects: "View Projects",
        download_cv: "Download CV",
        skills: "Skills Overview",
        programming: {
            title: "Programming",
            desc: "C/C++, Python, OpenCV, PyTorch. AI/ML workflows, scripting, Linux tooling.",
        },
        embedded: {
            title: "Embedded Systems",
            desc: "STM32, ESP32, PIC — bare-metal & HAL. UART, SPI, I²C, timers, interrupts, low-level C firmware.",
        },
        electronics: {
            title: "Electronics",
            desc: "Analog & digital circuit design, PCB prototyping, sensor/actuator interfacing, power stages.",
        },
        robotics: {
            title: "Robotics & Control",
            desc: "Autonomous systems, PID control, mechatronics integration. Competition experience.",
        },
        selected_projects: "Selected Projects",
        view_all: "View All",
    },
    fr: {
        portfolio: "👋 Bienvenue sur mon portfolio d'ingénierie",
        greeting: "Bonjour, je suis Marc.",
        subtitle: "Électronique, Systèmes Embarqués & Robotique",
        intro: "Je suis étudiant en 3ème année de génie électrique et électronique à l'Université de Selçuk, travaillant dans la robotique, la vision par ordinateur, l'IA et les systèmes embarqués. Je suis principalement orienté vers les logiciels (Python, C/C++ et Linux) mais je mets la main à la pâte avec le matériel quand c'est nécessaire.",
        view_projects: "Voir les projets",
        download_cv: "Télécharger CV",
        skills: "Aperçu des compétences",
        programming: {
            title: "Programmation",
            desc: "C/C++, Python, OpenCV, PyTorch. Workflows IA/ML, scripts, outils Linux.",
        },
        embedded: {
            title: "Systèmes Embarqués",
            desc: "STM32, ESP32, PIC — bare-metal & HAL. UART, SPI, I²C, timers, interruptions, firmware C bas niveau.",
        },
        electronics: {
            title: "Électronique",
            desc: "Conception de circuits, prototypage PCB, interfaçage capteurs/actionneurs, étages de puissance.",
        },
        robotics: {
            title: "Robotique & Contrôle",
            desc: "Systèmes autonomes, contrôle PID, intégration mécatronique. Expérience en compétition.",
        },
        selected_projects: "Projets Sélectionnés",
        view_all: "Voir tout",
    },
    tr: {
        portfolio: "👋 Mühendislik portföyüme hoş geldiniz",
        greeting: "Merhaba, ben Marc.",
        subtitle: "Elektronik, Gömülü Sistemler ve Robotik",
        intro: "Selçuk Üniversitesi'nde 3. sınıf Elektrik ve Elektronik Mühendisliği öğrencisiyim, robotik, bilgisayarlı görme, yapay zeka ve gömülü sistemler üzerinde çalışıyorum. Çoğunlukla yazılım tarafındayım (Python, C/C++ ve Linux) ancak gerektiğinde donanımla da ilgileniyorum.",
        view_projects: "Projeleri Gör",
        download_cv: "CV İndir",
        skills: "Yeteneklere Genel Bakış",
        programming: {
            title: "Programlama",
            desc: "C/C++, Python, OpenCV, PyTorch. YZ/ML iş akışları, betik, Linux araçları.",
        },
        embedded: {
            title: "Gömülü Sistemler",
            desc: "STM32, ESP32, PIC — bare-metal & HAL. UART, SPI, I²C, zamanlayıcılar, kesme, düşük seviye C.",
        },
        electronics: {
            title: "Elektronik",
            desc: "Devre tasarımı, PCB prototipleme, sensör/aktüatör arayüzü, güç katları.",
        },
        robotics: {
            title: "Robotik & Kontrol",
            desc: "Otonom sistemler, PID kontrol, mekatronik entegrasyon. Yarışma deneyimi.",
        },
        selected_projects: "Seçili Projeler",
        view_all: "Tümünü Gör",
    },
};
const t = texts[lang];
---

<BaseLayout title="Marc | Engineering Portfolio">
    <!-- ===================== HERO SECTION ===================== -->
    <header
        class="section pb-5"
        style="min-height: 80vh; display: flex; align-items: center;"
    >
        <div class="container w-100">
            <div
                class="grid grid-cols-1 md-grid-cols-2 align-items-center gap-5"
            >
                <!-- Text -->
                <div class="animate-fade-up">
                    <div
                        class="d-inline-block mb-3 px-3 py-2 small"
                        style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 9999px; font-weight: 500; color: var(--color-text-primary);"
                    >
                        {t.portfolio}
                    </div>
                    <h1 class="mb-3" style="font-size: 4rem;">
                        <span class="gradient-text">{t.greeting}</span>
                    </h1>
                    <h2
                        class="mb-4 fw-light"
                        style="font-size: 1.75rem; color: var(--color-text-secondary);"
                    >
                        {t.subtitle}
                    </h2>
                    <p class="lead mb-5">
                        {t.intro}
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a
                            href={translatePath("/projects")}
                            class="btn btn-primary"
                        >
                            {t.view_projects}
                        </a>
                        <a
                            href={`${import.meta.env.BASE_URL}/docs/cv.pdf`}
                            class="btn btn-outline disabled"
                            target="_blank"
                            style="opacity: 0.5; pointer-events: none;"
                        >
                            {t.download_cv}
                        </a>
                    </div>
                </div>

                <!-- Profile image -->
                <div class="d-flex justify-content-center">
                    <div
                        class="glass p-2 floating-container"
                        style="border-radius: 24px; max-width: 400px; width: 100%;"
                    >
                        <img
                            src={profileImg.src}
                            class="img-fluid profile-img-hero w-100"
                            alt="Marc Ravelontsalama"
                            style="border-radius: 16px; display: block;"
                        />
                    </div>
                </div>
            </div>
        </div>
    </header>

    <style>
        @keyframes rotate3In {
            0% {
                transform: perspective(1200px) rotateY(-30deg) rotateX(15deg)
                    translateZ(-100px) scale(0.9);
                opacity: 0;
                box-shadow: 0 0 0 rgba(59, 130, 246, 0);
            }

            100% {
                transform: perspective(1000px) rotateY(-8deg) rotateX(5deg)
                    scale(1.05);
                opacity: 1;
                box-shadow: 0 20px 40px rgba(59, 130, 246, 0.3);
            }
        }

        @keyframes floating3D {
            0%,
            100% {
                transform: translateY(0) rotateY(0deg) rotateX(0deg);
            }
            50% {
                transform: translateY(-15px) rotateY(3deg) rotateX(-2deg);
            }
        }

        .floating-container {
            animation: floating3D 6s ease-in-out 1.5s infinite;
            will-change: transform;
        }

        .profile-img-hero {
            animation: rotate3In 1.5s cubic-bezier(0.175, 0.885, 0.32, 1.275)
                both;
            transform-origin: center;
            backface-visibility: hidden;
            transform: perspective(1000px) rotateY(-8deg) rotateX(5deg)
                scale(1.05);
            box-shadow: 0 20px 40px rgba(59, 130, 246, 0.3);
        }
    </style>

    <!-- ===================== SKILLS SECTION ===================== -->
    <section class="section py-5">
        <div class="container">
            <h2 class="mb-5 section-title"><span>{t.skills}</span></h2>

            <div
                class="grid grid-cols-1 md-grid-cols-2 lg-grid-cols-4 gap-4 animate-fade-up"
                style="animation-delay: 0.2s;"
            >
                <div
                    class="glass p-4 h-100"
                    style="transition: transform 0.3s; cursor: default;"
                    onmouseover="this.style.transform='translateY(-5px)'"
                    onmouseout="this.style.transform='translateY(0)'"
                >
                    <h5
                        class="mb-3"
                        style="color: var(--color-accent-1); font-weight: 700;"
                    >
                        {t.programming.title}
                    </h5>
                    <p class="small text-muted mb-0">{t.programming.desc}</p>
                </div>

                <div
                    class="glass p-4 h-100"
                    style="transition: transform 0.3s; cursor: default;"
                    onmouseover="this.style.transform='translateY(-5px)'"
                    onmouseout="this.style.transform='translateY(0)'"
                >
                    <h5
                        class="mb-3"
                        style="color: var(--color-accent-2); font-weight: 700;"
                    >
                        {t.embedded.title}
                    </h5>
                    <p class="small text-muted mb-0">{t.embedded.desc}</p>
                </div>

                <div
                    class="glass p-4 h-100"
                    style="transition: transform 0.3s; cursor: default;"
                    onmouseover="this.style.transform='translateY(-5px)'"
                    onmouseout="this.style.transform='translateY(0)'"
                >
                    <h5
                        class="mb-3"
                        style="color: var(--color-accent-1); font-weight: 700;"
                    >
                        {t.electronics.title}
                    </h5>
                    <p class="small text-muted mb-0">{t.electronics.desc}</p>
                </div>

                <div
                    class="glass p-4 h-100"
                    style="transition: transform 0.3s; cursor: default;"
                    onmouseover="this.style.transform='translateY(-5px)'"
                    onmouseout="this.style.transform='translateY(0)'"
                >
                    <h5
                        class="mb-3"
                        style="color: var(--color-accent-2); font-weight: 700;"
                    >
                        {t.robotics.title}
                    </h5>
                    <p class="small text-muted mb-0">{t.robotics.desc}</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ===================== PROJECTS PREVIEW ===================== -->
    <section class="section py-5 mb-5">
        <div class="container">
            <div
                class="d-flex flex-wrap justify-content-between align-items-center mb-5 gap-3"
            >
                <h2 class="section-title mb-0" style="margin-bottom: 0;">
                    <span>{t.selected_projects}</span>
                </h2>
                <a
                    href={translatePath("/projects")}
                    class="btn btn-outline"
                    style="padding: 0.5rem 1.25rem;"
                >
                    <span class="gradient-text">{t.view_all}</span>
                </a>
            </div>

            <div
                class={`grid grid-cols-1 md-grid-cols-2 ${gridClassDesktop} gap-4 animate-fade-up`}
                style="animation-delay: 0.3s;"
            >
                {
                    activeProjects.map((project) => (
                        <ProjectCard project={project} lang={lang} />
                    ))
                }
            </div>
        </div>
    </section>
</BaseLayout>
