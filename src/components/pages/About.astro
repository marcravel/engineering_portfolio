                        </h5>
                        <p
                            class="mb-2 small fw-bold"
                            style="color: var(--color-accent-1);"
                        >
                            {t.edu1.year}
                        </p>
                        <p
                            class="small mb-3"
                            style="color: var(--color-text-secondary);"
                        >
                            {t.edu1.loc}
                        </p>
                        <div class="mt-2">
                            <span
                                class="badge px-3 py-2"
                                style="background: rgba(59, 130, 246, 0.1); color: #60a5fa; border-color: rgba(59, 130, 246, 0.3);"
                                >{t.edu1.badge}</span
                            >
                        </div>
                    </div>

                    <!-- Education Card 2 -->
                    <div class="glass p-4 mb-5 edu-card">
                        <h5
                            class="fw-bold mb-2"
                            style="color: var(--color-text-primary);"
                        >
                            {t.edu2.title}
                        </h5>
                        <p
                            class="mb-2 small fw-bold"
                            style="color: var(--color-accent-1);"
                        >
                            {t.edu2.year}
                        </p>
                        <p
                            class="small mb-3"
                            style="color: var(--color-text-secondary);"
                        >
                            {t.edu2.loc}
                        </p>
                        <div class="mt-2">
                            <span
                                class="badge px-3 py-2"
