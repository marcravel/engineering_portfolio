---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fs from "fs/promises";
import path from "path";
import { useTranslatedPath } from "../../i18n/ui";

export interface Props {
    lang: "en" | "fr" | "tr";
    project: any;
}
const { lang, project } = Astro.props;
const translatePath = useTranslatedPath(lang);

// Helper to determine the hero image URL with BASE_URL routing
let heroImage = project.image;
if (heroImage && !heroImage.startsWith("http")) {
    const baseUrl = import.meta.env.BASE_URL.endsWith("/")
        ? import.meta.env.BASE_URL
        : import.meta.env.BASE_URL + "/";
    heroImage = `${baseUrl}${heroImage}`;
}

let descriptionContent = project.longDescription
    ? typeof project.longDescription === "object"
        ? project.longDescription[lang]
        : project.longDescription
    : project.description[lang] || project.description.en;
let isTextFile =
    typeof descriptionContent === "string" &&
    descriptionContent.endsWith(".txt");
if (isTextFile) {
    try {
        const filePath = path.join(
            process.cwd(),
            "public",
            descriptionContent.replace(/^\/+/, ""),
        );
        descriptionContent = await fs.readFile(filePath, "utf-8");
    } catch (err) {
        console.error("Failed to read description file:", err);
        descriptionContent =
            project.description[lang] || project.description.en;
    }
}

const subtitleRegex = /^(Project Overview|Role & Responsibilities|System Architecture|Results & Recognition|Aperçu du Projet|Rôle et Responsabilités|Architecture du Système|Résultats et Reconnaissance|Proje Özeti|Rol ve Sorumluluklar|Sistem Mimarisi|Sonuçlar ve Başarılar):?$/i;

const parsedLongDescription = (
    typeof descriptionContent === "string" ? descriptionContent : ""
)
    .split("\n")
    .filter((p) => p.trim() !== "")
    .map((p) => {
        const trimmed = p.trim();
        if (subtitleRegex.test(trimmed)) {
            return `<h3 class="mb-3 mt-5" style="color: var(--color-accent-1); font-size: 1.5rem;">${trimmed}</h3>`;
        }
        return `<p class="mb-3 text-muted">${trimmed}</p>`;
    })
    .join("");

const t_back = {
    en: "Back to Projects",
    fr: "Retour aux projets",
    tr: "Projelere Dön",
};
const t_tech = {
    en: "Technologies Built With",
    fr: "Technologies Utilisées",
    tr: "Kullanılan Teknolojiler",
};
const t_gallery = { en: "Gallery", fr: "Galerie", tr: "Galeri" };
const t_overview = { en: "Overview", fr: "Aperçu", tr: "Genel Bakış" };
---

<BaseLayout title={`${project.title[lang]} - Marc Projects`}>
    <section class="section">
        <div class="container animate-fade-up">
            <!-- Navigation Back -->
            <div class="mb-5">
                <a
                    href={translatePath("/projects")}
                    class="text-decoration-none d-inline-flex align-items-center gap-2" style="color: var(--color-accent-1);"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        fill="currentColor"
                        viewBox="0 0 16 16"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"
                        ></path>
                    </svg>
                    <span style="font-weight: 500;">{t_back[lang]}</span>
                </a>
            </div>

            <!-- Project Header -->
            <div class="mb-5 text-center">
                <div class="mb-4">
                    <span class="badge px-4 py-2" style="background: rgba(59, 130, 246, 0.2); border: 1px solid rgba(59, 130, 246, 0.5); color: #fff; font-size: 1rem; text-transform: uppercase; letter-spacing: 1px;">
                        {project.category[lang]}
                    </span>
                </div>
                <h1 class="mb-4 gradient-text" style="font-size: 3rem;">{project.title[lang]}</h1>

                {
                    project.achievements && project.achievements[lang] && (
                        <div class="d-inline-block p-3 rounded glass mb-5" style="border-left: 3px solid var(--color-accent-2);">
                            <span
                                style="color: var(--color-text-primary); font-weight: 600;"
                            >
                                {project.achievements[lang]}
                            </span>
                        </div>
                    )
                }

                <!-- Technologies & Architecture right under title -->
                <div class="mb-5 d-flex flex-column align-items-center">
                    <h4
                        class="text-uppercase mb-3 small fw-bold"
                        style="color: var(--color-text-secondary); letter-spacing: 2px;"
                    >
                        {t_tech[lang]}
                    </h4>
                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        {
                            project.techStack.map((tech) => (
                                <span class="badge px-3 py-2" style="background: var(--color-bg-elevated); border: 1px solid var(--color-border); font-size: 0.9rem;">
                                    {tech}
                                </span>
                            ))
                        }
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg-grid-cols-3 gap-5">
                <!-- Left Column: Gallery -->
                <div class="order-2 lg-order-2">
                    {
                        project.gallery && project.gallery.length > 0 && (
                            <div class="glass p-4 sticky-top" style="top: 100px;">
                                <h3
                                    class="mb-4"
                                    style="color: var(--color-text-primary); font-size: 1.5rem;"
                                >
                                    {t_gallery[lang]}
                                </h3>
                                <div class="grid grid-cols-2 gap-3">
                                    {project.gallery.map((galleryImg) => {
                                        // Handle correct routing for gallery images
                                        let imgPath = galleryImg;
                                        if (!imgPath.startsWith("http")) {
                                            const bUrl =
                                                import.meta.env.BASE_URL.endsWith(
                                                    "/",
                                                )
                                                    ? import.meta.env.BASE_URL
                                                    : import.meta.env.BASE_URL +
                                                      "/";
                                            imgPath = `${bUrl}${imgPath}`;
                                        }
                                        return (
                                            <div
                                                class="glass overflow-hidden"
                                                style="cursor: pointer; aspect-ratio: 1; padding: 0;"
                                            >
                                                <img
                                                    src={imgPath}
                                                    class="h-100 w-100 gallery-image"
                                                    style="object-fit: cover; transition: transform 0.3s ease; display: block;"
                                                    alt="Project Gallery Image"
                                                    loading="lazy"
                                                />
                                            </div>
                                        );
                                    })}
                                </div>
                            </div>
                        )
                    }
                </div>

                <!-- Right Column: Media Hero & Description -->
                <div class="lg-grid-col-span-2 order-1 lg-order-1" style="grid-column: span 2;">
                    <!-- Media Hero (YouTube or Image) -->
                    <div
                        class="mb-5 glass overflow-hidden p-0"
                    >
                        {
                            project.youtubeId ? (
                                <div style="position: relative; width: 100%; padding-bottom: 56.25%;">
                                    <iframe
                                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                                        src={`https://www.youtube.com/embed/${project.youtubeId}?rel=0`}
                                        title="Technical hardware overview of the project"
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                        allowfullscreen
                                    />
                                </div>
                            ) : (
                                heroImage && (
                                    <img
                                        src={heroImage}
                                        alt={project.title[lang]}
                                        class="w-100"
                                        style="object-fit: cover; max-height: 500px; display: block;"
                                    />
                                )
                            )
                        }
                    </div>

                    <!-- Long Description -->
                    <div class="mb-5 glass p-4 md-p-5">
                        <h3
                            class="mb-4 gradient-text"
                            style="font-size: 2rem;"
                        >
                            {t_overview[lang]}
                        </h3>
                        <div class="project-details" style="line-height: 1.8; font-size: 1.1rem;">
                            <span set:html={parsedLongDescription} />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Custom Modal -->
            <div id="customImageModal" class="custom-modal">
                <div class="custom-modal-content">
                    <span class="custom-modal-close">&times;</span>
                    <img id="customModalImage" src="" alt="Large project image view" />
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .order-1 { order: 1; }
    .order-2 { order: 2; }
    @media (min-width: 1024px) {
        .lg-order-1 { order: 1; }
        .lg-order-2 { order: 2; }
    }
    
    .sticky-top {
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .gallery-image:hover {
        transform: scale(1.1);
    }
    
    /* Custom Modal Styles */
    .custom-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(10, 10, 10, 0.9);
        backdrop-filter: blur(5px);
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .custom-modal.show {
        display: flex;
        opacity: 1;
    }
    
    .custom-modal-content {
        position: relative;
        max-width: 90%;
        max-height: 90%;
    }
    
    .custom-modal-content img {
        max-width: 100%;
        max-height: 90vh;
        object-fit: contain;
        border-radius: 12px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }
    
    .custom-modal-close {
        position: absolute;
        top: -40px;
        right: 0;
        color: white;
        font-size: 40px;
        font-weight: bold;
        cursor: pointer;
        transition: color 0.3s;
    }
    
    .custom-modal-close:hover {
        color: var(--color-accent-1);
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const galleryImages = document.querySelectorAll(".gallery-image");
        const modal = document.getElementById("customImageModal");
        const modalImg = document.getElementById("customModalImage");
        const closeBtn = document.querySelector(".custom-modal-close");

        galleryImages.forEach((img) => {
            img.addEventListener("click", function () {
                if (modal && modalImg) {
                    modalImg.src = this.src;
                    modal.classList.add("show");
                    document.body.style.overflow = "hidden"; // Prevent scrolling
                }
            });
        });

        const closeModal = () => {
            if (modal) {
                modal.classList.remove("show");
                document.body.style.overflow = "auto";
            }
        };

        if (closeBtn) closeBtn.addEventListener("click", closeModal);
        
        if (modal) {
            modal.addEventListener("click", (e) => {
                if (e.target === modal) {
                    closeModal();
                }
            });
        }
    });
</script>
