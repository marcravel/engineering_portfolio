                            class="mb-4"
                            style="color: var(--color-accent-1); font-size: 1.5rem;"
                        >
                            {t.languages}
                        </h3>
                        <div class="d-flex flex-column gap-3">
                            <div
                                class="d-flex align-items-center justify-content-between"
                            >
                                <strong
                                    style="color: var(--color-text-primary);"
                                    >English</strong
                                >
                                <div
                                    style="flex-grow: 1; border-bottom: 1px dashed rgba(255,255,255,0.1); margin: 0 1rem;"
                                >
                                </div>
                                <span
                                    style="color: var(--color-text-secondary);"
                                    >{t.langLvl.pro}</span
                                >
                            </div>
                            <div
                                class="d-flex align-items-center justify-content-between"
                            >
                                <strong
                                    style="color: var(--color-text-primary);"
                                    >French</strong
                                >
                                <div
                                    style="flex-grow: 1; border-bottom: 1px dashed rgba(255,255,255,0.1); margin: 0 1rem;"
                                >
                                </div>
                                <span
                                    style="color: var(--color-text-secondary);"
                                    >{t.langLvl.fluent}</span
                                >
                            </div>
                            <div
                                class="d-flex align-items-center justify-content-between"
                            >
                                <strong
                                    style="color: var(--color-text-primary);"
                                    >Turkish</strong
                                >
                                <div
                                    style="flex-grow: 1; border-bottom: 1px dashed rgba(255,255,255,0.1); margin: 0 1rem;"
                                >
                                </div>
                                <span
                                    style="color: var(--color-text-secondary);"
                                    >{t.langLvl.fluent}</span
                                >
                            </div>
                            <div
                                class="d-flex align-items-center justify-content-between"
                            >
                                <strong
                                    style="color: var(--color-text-primary);"
                                    >German</strong
                                >
                                <div
                                    style="flex-grow: 1; border-bottom: 1px dashed rgba(255,255,255,0.1); margin: 0 1rem;"
                                >
                                </div>
                                <span
                                    style="color: var(--color-text-secondary);"
                                    >A1</span
                                >
                            </div>
                            <div
                                class="d-flex align-items-center justify-content-between"
                            >
                                <strong
                                    style="color: var(--color-text-primary);"
                                    >Malagasy</strong
                                >
                                <div
                                    style="flex-grow: 1; border-bottom: 1px dashed rgba(255,255,255,0.1); margin: 0 1rem;"
                                >
                                </div>
                                <span
                                    style="color: var(--color-text-secondary);"
                                    >{t.langLvl.native}</span
                                >
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Education & Experience -->
                <div>
                    <h3
                        class="mb-4"
                        style="color: var(--color-accent-2); font-size: 1.5rem;"
