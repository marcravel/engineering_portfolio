---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, useTranslatedPath, getRouteFromUrl, languages, flags } from '../i18n/ui';

const { title = "Marc | Engineering Portfolio" } = Astro.props;
const currentPath = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const route = getRouteFromUrl(Astro.url);
---
<!DOCTYPE html>
<html lang={lang} data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />

    <!-- Bootstrap 5 CSS (CDN) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;700&display=swap"
        rel="stylesheet">
        
    <!-- Client-side Routing and Language Auto-Detection -->
    <script is:inline>
        (function() {
            try {
                const storedLang = localStorage.getItem('preferredLang');
                const browserLang = navigator.language.split('-')[0];
                const supportedLangs = ['en', 'fr', 'tr'];
                const defaultLang = 'en';

                const currentPath = window.location.pathname;
                const basePath = '/engineering_portfolio';
                let pathWithoutBase = currentPath.replace(basePath, '');
                if(!pathWithoutBase.startsWith('/')) pathWithoutBase = '/' + pathWithoutBase;
                
                const currentDocLang = supportedLangs.find(l => pathWithoutBase.startsWith(`/${l}/`) || pathWithoutBase === `/${l}`) || defaultLang;

                if (!storedLang) {
                    const targetLang = supportedLangs.includes(browserLang) ? browserLang : defaultLang;
                    if (targetLang !== defaultLang && currentDocLang === defaultLang && (pathWithoutBase === '/' || pathWithoutBase === '')) {
                        localStorage.setItem('preferredLang', targetLang);
                        window.location.replace(basePath + '/' + targetLang + '/');
                    }
                }
            } catch(e) {}
        })();
    </script>
</head>

<body>
    <!-- ===================== NAVBAR ===================== -->
    <nav id="main-nav" class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href={translatePath('/')}>Marc</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                    <li class="nav-item">
                        <a class:list={['nav-link', { active: route === '/' }]} href={translatePath('/')}>{t('nav.home')}</a>
                    </li>
                    <li class="nav-item">
                        <a class:list={['nav-link', { active: route.includes('/about') }]} href={translatePath('/about')}>{t('nav.about')}</a>
                    </li>
                    <li class="nav-item">
                        <a class:list={['nav-link', { active: route.includes('/projects') }]} href={translatePath('/projects')}>{t('nav.projects')}</a>
                    </li>
                    <li class="nav-item">
                        <a class:list={['nav-link', { active: route.includes('/contacts') }]} href={translatePath('/contacts')}>{t('nav.contact')}</a>
                    </li>
                    
                    <!-- Language Switcher -->
                    <li class="nav-item dropdown ms-lg-3 mt-2 mt-lg-0">
                        <a class="nav-link dropdown-toggle badge bg-secondary bg-opacity-25 text-light px-3 py-2 rounded-pill fs-5" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="min-width: 60px;">
                            {flags[lang]}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
                            {Object.entries(languages).map(([code, name]) => (
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2" href={translatePath(route, code as keyof typeof languages)} onclick={`localStorage.setItem('preferredLang', '${code}')`}>
                                        <span class="fs-5">{flags[code as keyof typeof languages]}</span>
                                        <span>{name}</span>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <slot />

    <!-- ===================== FOOTER ===================== -->
    <footer class="py-4 footer-section bg-dark text-light mt-auto">
        <div class="container text-center small">
            <div class="mb-2">
                © <span id="currentYear"></span> Marc — Engineering Portfolio
            </div>
            <div>
                <a href="https://github.com/marcravel" target="_blank" rel="noopener noreferrer"
                    class="text-decoration-none text-light-50 me-2">{t('footer.github')}</a>
                <a href="https://www.linkedin.com/in/marc-anjaniaina-ravelontsalama/" target="_blank"
                    rel="noopener noreferrer" class="text-decoration-none text-light-50 me-2">{t('footer.linkedin')}</a>
                <a href={translatePath('/contacts')} class="text-decoration-none text-light-50">{t('footer.contact')}</a>
            </div>
        </div>
    </footer>

    <!-- ===================== SCRIPTS ===================== -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous">
        </script>
    <script src="/assets/js/main.js" is:inline></script>
    <script is:inline>
        document.getElementById('currentYear').textContent = new Date().getFullYear();

        // Transparent to Glassy Navbar Logic
        document.addEventListener("DOMContentLoaded", function () {
            const el_navbar = document.getElementById('main-nav');
            if (el_navbar) {
                window.addEventListener('scroll', function () {
                    if (window.scrollY > 10) {
                        el_navbar.classList.add('scrolled');
                    } else {
                        el_navbar.classList.remove('scrolled');
                    }
                });
            }
        });
    </script>
</body>

</html>