            loc: "Faculté de Technologie, Selçuk Üniversitesi | Konya, Turquie",
            badge: "🏆 Boursier du Gouvernement Turc"
        },
        edu2: {
            title: "Diplôme d'Études Secondaires (Scientifique)",
